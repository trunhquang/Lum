rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: string (optional)
    //   - lastLogin: string (optional)
    //   - customApiKey: string (optional)
    //
    // Collection: groups
    // Document ID: uuid
    // Fields:
    //   - userId: string (required, immutable)
    //   - name: string (required, < 100 chars)
    //   - description: string (optional, < 500 chars)
    //   - updatedAt: number (required)
    //   - icon: string (optional)
    //   - color: string (optional)
    //
    // Collection: notes
    // Document ID: uuid
    // Fields:
    //   - userId: string (required, immutable)
    //   - content: string (required, < 10000 chars)
    //   - title: string (optional, < 200 chars)
    //   - timestamp: number (required)
    //   - groupId: string (optional)
    //   - type: string (required, in ['text', 'url'])
    //   - aiSummary: string (optional)
    //   - isBookmarked: bool (optional)
    //   - translatedContent: string (optional)
    //   ... (processing fields)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "trunhquang@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    function isDocOwner() {
      return isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    function isNewDocOwner() {
      return isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin());
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('customApiKey' in data) || (data.customApiKey is string && data.customApiKey.size() < 200));
    }

    function isValidNote(data) {
      return data.keys().hasAll(['userId', 'content', 'timestamp']) &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.content is string && data.content.size() < 100000 &&
             data.timestamp is number &&
             (!('title' in data) || (data.title is string && data.title.size() < 500)) &&
             (!('type' in data) || data.type in ['text', 'url']);
    }

    function isValidGroup(data, isCreate) {
      return (isCreate ? data.keys().hasAll(['userId', 'name', 'updatedAt']) : true) &&
             (!('userId' in data) || data.userId == request.auth.uid || isAdmin()) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 100)) &&
             (!('updatedAt' in data) || data.updatedAt is number) &&
             (!('topicId' in data) || (data.topicId is string && (data.topicId == "" || data.topicId.size() < 100)));
    }

    function isValidTopic(data, isCreate) {
      return (isCreate ? data.keys().hasAll(['userId', 'name', 'updatedAt']) : true) &&
             (!('userId' in data) || data.userId == request.auth.uid || isAdmin()) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 100)) &&
             (!('updatedAt' in data) || data.updatedAt is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.email == resource.data.email || isAdmin());
    }

    match /groups/{groupId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidGroup(request.resource.data, true);
      allow update: if isDocOwner() && isValidGroup(request.resource.data, false) &&
                    (request.resource.data.userId == resource.data.userId || isAdmin());
      allow delete: if isDocOwner();
    }

    match /topics/{topicId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidTopic(request.resource.data, true);
      allow update: if isDocOwner() && isValidTopic(request.resource.data, false) &&
                    (request.resource.data.userId == resource.data.userId || isAdmin());
      allow delete: if isDocOwner();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidNote(request.resource.data);
      allow update: if isDocOwner() && isValidNote(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
